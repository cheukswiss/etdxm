{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "etdxm/plan.schema.json",
  "title": "中书省草案",
  "description": "中书省提交门下审议的草案。canonical 规约，运行时强制实现见 .claude/hooks/lib/validate-payload.sh",
  "type": "object",
  "required": ["plan_id", "objective", "subtasks"],
  "properties": {
    "plan_id": { "type": "string", "pattern": "^PLAN-" },
    "objective": { "type": "string", "minLength": 1 },
    "subtasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "assigned_to", "description"],
        "properties": {
          "id": { "type": "string" },
          "assigned_to": {
            "type": "string",
            "enum": ["gongbu", "xingbu", "hubu", "bingbu", "libu", "libu_hr"]
          },
          "parallel_group": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
    "risk_notes": { "type": "string" }
  }
}
